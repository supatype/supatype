# Copy to `.env`, then from this directory:
#   pnpm exec supatype keys
#   pnpm exec supatype push
#   pnpm exec supatype dev
#
# `supatype dev` / `supatype keys` also sync EXPO_PUBLIC_* for the Expo app.

DATABASE_URL=postgresql://supatype_admin:postgres@localhost:5432/expo-auth
POSTGRES_USER=supatype_admin
POSTGRES_PASSWORD=postgres
POSTGRES_DB=expo-auth

# JWT — run `supatype keys` (or start `supatype dev`) to mint ANON_KEY / SERVICE_ROLE_KEY
JWT_SECRET=super-secret-jwt-token-change-in-production
ANON_KEY=
SERVICE_ROLE_KEY=

# Local API gateway (Kong). Change SUPATYPE_KONG_PORT if 18473 is taken.
SUPATYPE_KONG_PORT=18473
PUBLIC_SUPATYPE_URL=http://localhost:18473
API_EXTERNAL_URL=http://localhost:18473
SITE_URL=supatype-expo-auth://

# Expo app (read by Metro via EXPO_PUBLIC_*)
EXPO_PUBLIC_SUPATYPE_URL=http://localhost:18473
EXPO_PUBLIC_SUPATYPE_ANON_KEY=

# Email redirects / magic links — console provider logs to the server
GOTRUE_MAILER_AUTOCONFIRM=true
