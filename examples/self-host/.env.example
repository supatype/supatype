POSTGRES_USER=supatype_admin
POSTGRES_PASSWORD=postgres
POSTGRES_DB=self_host_example

JWT_SECRET=super-secret-jwt-token-change-in-production
ANON_KEY=
SERVICE_ROLE_KEY=

API_EXTERNAL_URL=http://localhost:18473
SITE_URL=http://localhost:3000

GOTRUE_MAILER_AUTOCONFIRM=true
DISABLE_SIGNUP=false

# Optional image pin for beta testing.
# Leave unset to use compose defaults.
SUPATYPE_POSTGRES_IMAGE=supatype/postgres:17-latest
SUPATYPE_SERVER_IMAGE=supatype/auth:v1.0.0
SUPATYPE_STORAGE_IMAGE=supatype/storage:0.1.0-alpha.6
SUPATYPE_REALTIME_IMAGE=supatype/realtime:latest
SUPATYPE_STUDIO_IMAGE=supatype/studio:latest
SUPATYPE_SCHEMA_ENGINE_IMAGE=supatype/schema-engine:v0.1.0-alpha.3
