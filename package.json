{
  "name": "supatype",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "node --env-file=.env node_modules/.bin/turbo run dev",
    "supatype": "node packages/cli/bin/definatype.js",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "build:engine": "cargo build --workspace",
    "build:engine:release": "cargo build --workspace --release",
    "test:engine": "cargo test --workspace",
    "clean": "turbo run clean && cargo clean"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.6.0"
}
