{
  "name": "@supatype/ssr",
  "version": "0.1.5",
  "description": "Supatype server-side rendering utilities — create a client from cookie-based auth for Server Components, Route Handlers, and middleware",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@supatype/client": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5"
  }
}
