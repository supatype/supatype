{
  "name": "@supatype/cli",
  "version": "0.1.3",
  "description": "Supatype CLI — schema push, introspect, generate",
  "type": "module",
  "bin": {
    "supatype": "./bin/supatype.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./seed": {
      "import": "./dist/seed.js",
      "types": "./dist/seed.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && node --input-type=module -e \"import{cpSync,mkdirSync}from'node:fs';const a='dist/assets';mkdirSync(a,{recursive:true});cpSync('assets/supatype-logo-wordmark.ascii.txt',a+'/supatype-logo-wordmark.ascii.txt')\"",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "postinstall": "node --input-type=module --eval \"import{existsSync}from'node:fs';import{resolve}from'node:path';import{pathToFileURL}from'node:url';const f=resolve(process.cwd(),'dist/scripts/postinstall.js');if(existsSync(f))await import(pathToFileURL(f).href)\"",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "ink": "^5.2.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "commander": "^12.1.0",
    "pg": "^8.13.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.3.18",
    "@types/node": "^22",
    "@types/pg": "^8",
    "vitest": "^4.0.18"
  }
}
