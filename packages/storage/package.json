{
  "name": "@supatype/storage",
  "version": "0.1.0",
  "description": "Supatype storage service — file upload, download, and image transformation",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "pg": "^8.13.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/pg": "^8",
    "tsx": "^4",
    "typescript": "^5"
  }
}
